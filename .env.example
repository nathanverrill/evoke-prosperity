# EVOKE Prosperity Environment Configuration

# Infrastructure Secret (used for all services)
INFRA_SECRET=devsecret123

# Port Configuration
PORT_POSTGRES=5432
PORT_MINIO_API=9000
PORT_MINIO_CONSOLE=9001
PORT_REDPANDA_OUTSIDE=9092
PORT_REDPANDA_UI=8080
PORT_OS_DASHBOARDS=5601
PORT_OPENWEBUI=3000
PORT_MINECRAFT=25565
PORT_MINECRAFT_BEDROCK=19132
PORT_MINECRAFT_RCON=25575
PORT_EVOKE=8000
PORT_BRIGHTSPACE_SIM=8001

# Address shown to learners in the web app's Minecraft connect flow --
# NOT the internal container hostname (MINECRAFT_HOST below), which is
# only for the app/bridge's own RCON traffic. "localhost" is correct only
# when a learner's Minecraft client runs on the same machine as this
# stack; set to your LAN IP or real domain otherwise.
MINECRAFT_PUBLIC_HOST=localhost

# Ports shown alongside MINECRAFT_PUBLIC_HOST above -- independent of
# PORT_MINECRAFT/PORT_MINECRAFT_BEDROCK (which control the actual Docker
# host-port binding). Only diverges from the defaults below if you're
# forwarding from a different external port than the container's real bind
# port (e.g. a router-level remap to dodge routine internet-wide Minecraft
# server scanners, which target the default ports specifically).
# MINECRAFT_PUBLIC_PORT_JAVA=25565
# MINECRAFT_PUBLIC_PORT_BEDROCK=19132

# Database
DATABASE_URL=postgresql://evoke:devsecret123@localhost:5432/evoke

# Redpanda/Kafka
REDPANDA_BROKER=redpanda:29092

# OpenSearch
OPENSEARCH_NODE=http://opensearch:9200

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=devsecret123

# OpenWebUI (for AI) -- run evoke-infra/openwebui-bootstrap.py once to create
# the "billbot" persona/knowledge and print the API key it needs below.
# Nothing in the app talks to OpenWebUI directly anymore (see
# GUARDRAILS_PLAN.md) -- OPENWEBUI_API_KEY is consumed by the litellm
# container itself (evoke-infra/litellm/config.yaml), which is the one
# thing that still calls OpenWebUI. The app talks to litellm instead, via
# AI_GATEWAY_URL/LITELLM_MASTER_KEY below.
OPENWEBUI_API_KEY=

# LiteLLM gateway -- the one place content-filter/PII guardrails run before
# any real AI call site reaches OpenWebUI. LITELLM_MASTER_KEY is this
# gateway's own auth secret (shared between the litellm container and every
# app service that calls it); change it for anything beyond local dev.
PORT_LITELLM=4000
LITELLM_MASTER_KEY=sk-devsecret123

# Local LLM backend. Default is a containerized Ollama (evoke-infra's own
# "ollama" service) that pulls OLLAMA_MODEL automatically on first
# `docker compose up` -- works out of the box on a fresh clone, no native
# install needed, at the cost of a multi-GB download the first time and
# CPU-only inference (slower) since Docker Desktop can't pass Apple's
# Metal/GPU through to a container on Mac. If you already run Ollama
# natively (faster on Mac for this reason), point at it instead:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b
# OLLAMA_BASE_URL=http://ollama:11434  # this is already the default; uncomment+edit to override

# Gates /api/admin/* (roster import, team management, mission release/stage)
# with HTTP Basic auth -- this was completely open before. Change these
# defaults before exposing the app beyond localhost (ngrok, a real domain,
# etc.); leaving them as-is is equivalent to no auth at all.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=devsecret123

# The LMS -- architecturally this could be Brightspace or Moodle (every
# EVOKE deployment has exactly one, see ARCHITECTURE.md's "LMS is an
# engine-wide invariant"), but only a Brightspace adapter is actually built
# today; Moodle support doesn't exist yet. Hence these vars being
# Brightspace-named specifically rather than a generic LMS_*.
BRIGHTSPACE_SIM_URL=http://brightspace-sim:8001

# Minecraft
MINECRAFT_HOST=minecraft
MINECRAFT_RCON_PORT=25575
RCON_PASSWORD=devsecret123

# evoke-minecraft-bridge's real RCON target -- override to point the reward-
# delivery bridge at an externally-hosted Minecraft server (e.g. Apex Hosting)
# instead of the local `minecraft` container. Unset, it falls back to local.
# MINECRAFT_BRIDGE_HOST=your-host.example.com
# MINECRAFT_BRIDGE_RCON_PORT=25575
# MINECRAFT_BRIDGE_RCON_PASSWORD=

# Collective world-state pacing: cohort mission completions per Keel
# Restoration stage. Default 2 = demo-friendly (one learner can advance the
# world); a real classroom sets roughly roster*12/8 so the final stage
# lands near campaign end. See evoke/world_state.py for variants.
WORLD_STAGE_STEP=2

# Where the bridge builds the Restoration Beacon ("x y z"). Unset, it
# anchors once near the first player online at the first stage advance and
# remembers the spot (world_meta). Set explicitly for a curated world.
# KEEL_BEACON_POS=0 105 0

# Overrides the URL encoded in the Field Kit QR (else derived from the
# request's Host header). Set to a LAN-IP or real domain so phones can
# reach it.
# PUBLIC_WEB_URL=http://192.168.1.50:8000

# Auto-starts an ngrok tunnel to the web app on every `quick-start.sh` run
# and points PUBLIC_WEB_URL at it -- off by default. Turning this on exposes
# this instance to the public internet, including the unprotected
# /api/admin/* routes (see GAPS.md: "Auth is dev-grade" -- there is no real
# login gating them). Requires the ngrok CLI installed and authenticated
# (`ngrok config add-authtoken <token>`) before starting the stack. The free
# plan hands out a new random URL on every restart unless you have a
# reserved domain.
ENABLE_NGROK=false

# A free reserved/static domain from your ngrok account (ngrok dashboard ->
# Domains). When set, quick-start.sh passes --domain=<this> so the tunnel
# URL stays constant across restarts instead of a new random one every time.
# Per-machine -- each dev on the team gets their own from their own account.
# NGROK_STATIC_DOMAIN=your-name.ngrok-free.app

# Features
AI_ENABLED=true


# Brightspace -- server-to-server API creds (roster, classlist, dropbox
# submissions via evoke/lms/brightspace_lms.py), separate from the OAuth
# login flow below even though they can share the same app registration.
# Leave blank for local dev -- a fresh clone with these empty (or this whole
# block untouched) still gets today's dev auto-login as Player One.
BRIGHTSPACE_CLIENT_ID=
BRIGHTSPACE_CLIENT_SECRET=

# Brightspace OAuth 2.0 login ("Login with Central Registry" button) --
# a real user authorizing as themselves, distinct from the server-to-server
# creds above and from the LTI 1.3 platform-launch flow
# (evoke/lti/brightspace_lti_provider.py). Auth/token endpoints are fixed
# and not tenant-specific -- see https://docs.valence.desire2learn.com/basic/oauth2.html.
# Must match a Redirect URI registered in Brightspace's Manage Extensibility
# admin tool exactly.
# AUTH_PROVIDER left blank on purpose -- get_auth_provider() (evoke/
# oauth_providers.py) treats an unset/unrecognized value as "no real login
# configured" and falls back to dev-login, same as no LTI configured falls
# back today. A previous draft of this file set this to "brightspace" by
# default, which combined with non-empty placeholder text below would have
# made is_configured() return true on ANY fresh clone that just copies this
# file verbatim (quick-start.sh's own default behavior) -- breaking the
# "auto-signed-in as Player One" experience README.md promises. Only set
# this once BRIGHTSPACE_CLIENT_ID/SECRET/TENANT_URL below are real.
AUTH_PROVIDER=
BRIGHTSPACE_OAUTH_AUTHORIZE_URL=https://auth.brightspace.com/oauth2/auth
BRIGHTSPACE_OAUTH_TOKEN_URL=https://auth.brightspace.com/core/connect/token
BRIGHTSPACE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/brightspace/callback
BRIGHTSPACE_OAUTH_SCOPES=core:*:*

# Your real Brightspace instance URL (e.g. https://yourschool.brightspacedemo.com)
# -- used post-login to call the tenant-specific whoami API and identify who
# just signed in. Already referenced elsewhere in main.py (BrightspaceLMS,
# LTI issuer) but was never actually documented here until now. Required for
# the OAuth login provider (evoke/oauth_providers.py) -- no brightspace-sim
# fallback; unset means AUTH_PROVIDER=brightspace is treated as not configured.
BRIGHTSPACE_TENANT_URL=https://yourschool.brightspacedemo.com

# The Brightspace course (org unit) ID team sync reads Groups from --
# visible in that course's own Brightspace URL (.../d2l/home/<this number>).
# Optional: login still works without it, just with no team resolved (see
# evoke/oauth_providers.py's _resolve_team_name). Brightspace's own Groups
# feature is the source of truth for team assignment now -- no separate
# Evoke-side admin step to add a user's team.
BRIGHTSPACE_ORG_UNIT_ID=

# Real tenants version-lock their supported Brightspace API range -- checked
# live against charge.yacenter.org, whose max `lp` product version is 1.61
# (brightspace-sim's own whoami route is hardcoded to a fictional 1.96, which
# is why this can't just reuse that constant). 1.43 is old enough to be
# broadly supported across real tenants; override per-tenant if needed.
BRIGHTSPACE_WHOAMI_VERSION=1.43

# Real session hardening (evoke/auth_session.py) -- signs the httponly
# session cookie every route relies on now (get_current_user/require_self/
# get_current_admin) instead of trusting a client-supplied user_id. The
# fallback below is fine for a fresh local clone with no real students in
# it, but generate a real random value before any real pilot:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=dev-only-insecure-secret-change-me

# The one non-Brightspace login (POST /api/admin/login), for reaching
# #/admin without an LMS account -- everything about students (roster,
# teams, roles) is Brightspace's job now. Disabled unless
# EVOKE_ADMIN_PASSWORD_HASH is set -- see scripts/hash_admin_password.py.
EVOKE_ADMIN_USERNAME=admin
EVOKE_ADMIN_PASSWORD_HASH=